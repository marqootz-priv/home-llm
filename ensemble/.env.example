# Ensemble multi-agent voice assistant — copy to .env and fill in

ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=...
MATILDA_VOICE_ID=...
LEON_VOICE_ID=...
HA_URL=http://homeassistant.local:8123
HA_TOKEN=eyJ...

# Optional — if unset, DuckDuckGo (free) is used for search_web
# BRAVE_API_KEY=...

# Optional
# ENSEMBLE_PORT=8000
# MEMORY_DB_PATH=/path/to/ensemble_memory.db
# CLAUDE_MODEL=claude-sonnet-4-20250514
